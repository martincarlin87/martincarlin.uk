{
    "preset": "laravel",
    "rules": {
        "concat_space": {
            "spacing": "one"
        },
        "blank_line_before_statement": {
            "statements": [
                "if",
                "for",
                "foreach",
                "while",
                "switch",
                "try",
                "return",
                "throw",
                "break",
                "continue"
            ]
        },
        "not_operator_with_successor_space": false,
        "declare_strict_types": true,
        "phpdoc_separation": {
            "groups": [
                ["deprecated", "link", "see", "since"],
                ["author", "copyright", "license"],
                ["category", "package", "subpackage"],
                ["property", "property-write"],
                ["property-read"],
                ["param", "return"]
            ]
        }
    }
}
